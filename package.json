  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/tobiaghiraldini/operational/issues"
  },
  "homepage": "https://github.com/tobiaghiraldini/operational#readme",
  "devDependencies": {
    "@copyfactory/alpine-flow": "^0.3.1",
    "@tailwindcss/cli": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  }
}
