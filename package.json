{
  "name": "operational",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./static/css/tailwind.input.css -o ./static/css/home.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./static/css/tailwind.input.css -o ./static/css/home.css --watch",
    "build:dashboard:css": "npx @tailwindcss/cli -i ./static/css/dashboard.input.css -o ./static/css/dashboard.css --minify",
    "watch:dashboard:css": "npx @tailwindcss/cli -i ./static/css/dashboard.input.css -o ./static/css/dashboard.css --watch",
    "build:workflow-editor": "npm --prefix frontend/workflow-editor ci && npm --prefix frontend/workflow-editor run build",
    "watch:workflow-editor": "npm --prefix frontend/workflow-editor run dev",
    "vendor:alpine-flow": "mkdir -p static/vendor/alpine-flow/0.3.1 && cp node_modules/@copyfactory/alpine-flow/dist/flow.css node_modules/@copyfactory/alpine-flow/dist/alpine-flow.cdn.min.js static/vendor/alpine-flow/0.3.1/",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiaghiraldini/operational.git"
  },
  "keywords": [],
  "author": "",
