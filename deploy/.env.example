# Copy to operational/.env on the server and fill in values.
# Loaded automatically by operational/settings.py (python-dotenv).

# --- Required for production ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=.operational.cloud,operational.cloud,localhost,127.0.0.1

# PostgreSQL (run deploy/postgres/create_operational_db.sh first)
OPERATIONAL_DB_NAME=operational
OPERATIONAL_DB_USER=tobia
OPERATIONAL_DB_PASSWORD=
OPERATIONAL_DB_HOST=localhost
OPERATIONAL_DB_PORT=5432

# django-tenant-users default domain for new tenants
TENANT_USERS_DOMAIN=operational.cloud

# Static/media (run deploy/nginx/prepare_www_dirs.sh on the server)
STATIC_ROOT=/var/www/operational/static
MEDIA_ROOT=/var/www/operational/media

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=django-db
